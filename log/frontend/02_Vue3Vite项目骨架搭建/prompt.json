    "cross_system_consistency": {
      "field_naming": {
        "rule": "Java camelCase ↔ Python/JSON snake_case ↔ TypeScript camelCase（JSON传输统一snake_case）",
        "mappings": [
          { "java": "educationLevel", "python": "education_level", "json": "education_level" },
          { "java": "knowledgeLevel", "python": "knowledge_level", "json": "knowledge_level" },
          { "java": "preferredStyle", "python": "preferred_style", "json": "preferred_style" },
          { "java": "paperId", "python": "paper_id", "json": "paper_id" },
          { "java": "analysisId", "python": "analysis_id", "json": "analysis_id" }
        ]
      },
      "api_contracts": [
        {
          "endpoint": "/api/users/login",
          "method": "POST",
          "request_format": { "username": "string", "password": "string" },
          "response_format": { "code": 200, "data": { "token": "string", "userId": "string", "username": "string", "hasProfile": "boolean" } }
        }
      ],
      "data_flow": "前端Axios → Java后端REST API → Python AI服务，SSE反向推送：Python → Java → 前端EventSource"
    },
    "security_requirements": [
      { "category": "jwt_auth", "requirement": "JWT Token存储在LocalStorage，请求拦截器自动注入Authorization: Bearer {token}" },
      { "category": "sensitive_info", "requirement": "Token不存储在Cookie中，防止CSRF攻击" },
      { "category": "xss", "requirement": "用户输入需转义，markdown-it配置html:false" }
    ]
  },
  "constraints": {
    "naming": {
      "typescript": {
        "class_name": "PascalCase",
        "method_variable": "camelCase",
        "constant": "UPPER_SNAKE_CASE",
        "file_name": "PascalCase.vue（组件）/ camelCase.ts（工具/Store/API）",
        "enum_value": "PascalCase"
      },
      "json": { "field_name": "snake_case" },
      "cross_system_mapping": [
        { "java": "educationLevel", "python": "education_level", "json": "education_level" },
        { "java": "knowledgeLevel", "python": "knowledge_level", "json": "knowledge_level" },
        { "java": "preferredStyle", "python": "preferred_style", "json": "preferred_style" },
        { "java": "paperId", "python": "paper_id", "json": "paper_id" },
        { "java": "analysisId", "python": "analysis_id", "json": "analysis_id" }
      ]
    },
    "layering": {
      "frontend": { "rule": "View → Store → API，异步操作在Actions中，组件不直接调用API" }
    },
    "error_handling": {
      "frontend": { "approach": "Axios响应拦截器统一错误处理 + ElMessage提示" }
    },
    "caching": {
      "pattern": "前端不直接管理缓存，由Java后端Cache-Aside模式管理Redis缓存",
      "ttl_layers": []
    },
    "logging": {
      "prohibited": ["在循环中打印INFO及以上级别日志", "在日志中输出敏感信息（密码、Token、API Key）"]
    },
    "security": {
      "auth_mechanism": "JWT Token (24h有效期) + Redis黑名单",
      "public_endpoints": ["/api/users/register", "/api/users/login"],
      "data_isolation": "用户只能访问自己的会话和分析结果"
    }
  },
