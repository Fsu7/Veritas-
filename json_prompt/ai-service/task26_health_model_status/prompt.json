  "implementation_requirements": {
    "functional_requirements": [
      {
        "id": "FR-001",
        "description": "/health 端点实现 critical_ok 规则：当 llm.status == 'loaded' AND embedding.status in ('loaded', 'loaded_api', 'loaded_local') AND chroma.status == 'connected' 时返回 200 + status:UP；否则返回 503 + status:DEGRADED。",
        "priority": "P0",
        "acceptance_condition": "模拟 embedding.status='error'，GET /health 返回 503 + {code:503, message:'DEGRADED', data:{status:'DEGRADED', llm:'loaded', embedding:'error', chroma:'connected', ...}, timestamp:...}"
      },
      {
        "id": "FR-002",
        "description": "/health data 字段必须含 llm/embedding/chroma/prompts/searchService/reranker 6 个组件状态。",
        "priority": "P0",
        "acceptance_condition": "正常 200 响应 data 含 6 个键，值分别为对应服务的 status 字符串"
      },
      {
        "id": "FR-003",
        "description": "ModelStatusResponse 扩展字段：providerCandidates(List[str])：所有加载的 LLM provider mode 列表（['builtin','api','local']）；chromaPaperCount(int?)：ChromaDB 中论文数量；gpuMemoryUsed(str?)：GPU 显存使用（仅当本地模型加载时）；llmProviderCount(int)：加载的 provider 数量。",
        "priority": "P0",
        "acceptance_condition": "GET /api/model/status 返回 data 含 providerCandidates（至少一个元素）、chromaPaperCount（>=0）、llmProviderCount（>=1）"
      },
      {
        "id": "FR-004",
        "description": "model_status endpoint 从 app_state.llm_service.providers.keys() 提取 providerCandidates；从 vector_store_service.collection.count() 提取 chromaPaperCount；从 settings.LLM_BUILTIN_URL 是否配置判断 builtin 是否可用。",
        "priority": "P0",
        "acceptance_condition": "DeepSeek V4 Flash 配置下，返回 data.activeLlmProvider='api', providerCandidates=['api'], llmProviderCount=1"
      },
      {
        "id": "FR-005",
        "description": "GPU 显存查询：使用 try-except 包装 torch.cuda.memory_allocated() / memory_reserved()，异常时返回 None（不抛错）。仅当 LocalLLMProvider 加载时才显示。",
        "priority": "P1",
        "acceptance_condition": "本地模型未加载时，gpuMemoryUsed=None；本地模型加载后，gpuMemoryUsed='4.2GB / 16GB'"
      }
    ],
