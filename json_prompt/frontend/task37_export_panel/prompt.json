        "rule": "Java camelCase ↔ Python/JSON snake_case",
        "mappings": [
          { "java": "analysisId", "python": "analysis_id", "json": "analysis_id" }
        ]
      },
      "api_contracts": [
        { "endpoint": "/api/analysis/{analysisId}/export/pdf", "method": "GET", "request_format": { "Authorization": "Bearer JWT" }, "response_format": "application/pdf Blob" },
        { "endpoint": "/api/analysis/{analysisId}/export/word", "method": "GET", "request_format": { "Authorization": "Bearer JWT" }, "response_format": "application/vnd.openxmlformats-officedocument.wordprocessingml.document Blob" }
      ],
      "data_flow": "用户点击导出 → ExportPanel调用analysisApi → Java后端 → 文件Blob → 前端触发下载"
    }
