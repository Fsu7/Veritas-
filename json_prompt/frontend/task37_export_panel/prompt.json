  "constraints": {
    "naming": { "typescript": { "class_name": "PascalCase", "method_variable": "camelCase", "file_name": "PascalCase.vue" }, "json": { "field_name": "snake_case" }, "cross_system_mapping": [{ "java": "analysisId", "python": "analysis_id", "json": "analysis_id" }] },
    "layering": { "frontend": { "rule": "ExportPanel通过analysisApi调用后端，不直接操作Axios" } },
