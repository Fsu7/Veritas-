  "implementation_requirements": {
    "functional_requirements": [
      {"id": "FR-001", "description": "variables.scss补充变量：--chart-height-lg: 450px、--chart-height-md: 400px、--chart-height-sm: 300px、--font-size-display: 48px、--breakpoint-sm: 640px、--breakpoint-md: 768px、--breakpoint-lg: 1024px、--breakpoint-xl: 1280px", "priority": "P0", "acceptance_condition": "新增变量定义正确"},
      {"id": "FR-002", "description": "mixins.scss新建：@mixin respond-to($bp)响应式断点（@media (max-width: var(--breakpoint-#{$bp}))）、@mixin text-truncate($lines:1)文本截断（单行overflow:hidden+text-overflow:ellipsis+white-space:nowrap；多行-webkit-line-clamp）、@mixin flex-center($direction:row)居中（display:flex+align-items:center+justify-content:center）", "priority": "P1", "acceptance_condition": "mixin定义正确可复用"},
      {"id": "FR-003", "description": "global.scss补充工具类：.card-shadow（box-shadow:var(--shadow-md)）、.text-primary（color:var(--color-primary)）、.text-secondary（color:var(--text-color-secondary)）、.text-success/.text-warning/.text-danger、.bg-primary（background-color:var(--color-primary)）", "priority": "P1", "acceptance_condition": "工具类定义完整"},
      {"id": "FR-004", "description": "清理HomeView硬编码48px→var(--font-size-display)；AgentFlowChart硬编码450px→var(--chart-height-lg)；TimeStats硬编码400px→var(--chart-height-md)", "priority": "P0", "acceptance_condition": "硬编码值替换为CSS变量"},
      {"id": "FR-005", "description": "全局扫描所有.vue文件的<style>块，清理硬编码尺寸值（px/rem），替换为对应CSS变量（间距用var(--spacing-*)、字号用var(--font-size-*)、圆角用var(--radius-*)、阴影用var(--shadow-*)、颜色用var(--color-*)或var(--text-color-*)）", "priority": "P0", "acceptance_condition": "无硬编码尺寸值"},
      {"id": "FR-006", "description": "统一按钮尺寸：全局el-button使用size='default'（标准）、size='small'（紧凑）、size='large'（突出），禁止硬编码padding/font-size", "priority": "P1", "acceptance_condition": "按钮尺寸统一"},
      {"id": "FR-007", "description": "统一表单间距：el-form-item使用var(--spacing-md)间距，el-input/el-select使用统一高度", "priority": "P2", "acceptance_condition": "表单间距统一"}
