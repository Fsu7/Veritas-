  "constraints": {
    "naming": {
      "java": {
        "class_name": "PascalCase",
        "method_variable": "camelCase",
        "constant": "UPPER_SNAKE_CASE",
        "file_name": "PascalCase.java",
        "enum_value": "UPPER_SNAKE_CASE",
        "config_key": "kebab-case"
      },
      "json": {
        "field_name": "snake_case"
      },
      "cross_system_mapping": [
        { "java": "educationLevel", "python": "education_level", "json": "education_level" },
        { "java": "knowledgeLevel", "python": "knowledge_level", "json": "knowledge_level" },
        { "java": "preferredStyle", "python": "preferred_style", "json": "preferred_style" },
        { "java": "paperId", "python": "paper_id", "json": "paper_id" },
        { "java": "analysisId", "python": "analysis_id", "json": "analysis_id" }
      ]
    },
    "layering": {
      "java": {
        "rule": "Controller → Service → Repository → Client，禁止跨层",
        "entity_dto_separation": true,
        "dto_naming": "XxxRequest, XxxResponse（dto/request和dto/response子包）"
      }
    },
    "error_handling": {
      "java": {
        "approach": "BusinessException + GlobalExceptionHandler(@RestControllerAdvice)",
        "business_exception_fields": ["code", "message", "errorKey"]
      }
    },
    "caching": {
      "pattern": "Cache-Aside：写MySQL后删Redis缓存",
      "ttl_layers": [
        { "cache_name": "用户画像", "key_pattern": "user:profile:{userId}", "ttl": "1h" },
        { "cache_name": "用户信息", "key_pattern": "user:info:{userId}", "ttl": "1h" },
        { "cache_name": "论文详情", "key_pattern": "paper:detail:{paperId}", "ttl": "30min" },
        { "cache_name": "检索结果", "key_pattern": "search:result:{queryHash}", "ttl": "10min" },
        { "cache_name": "分析结果", "key_pattern": "analysis:result:{analysisId}", "ttl": "30min" },
        { "cache_name": "会话状态", "key_pattern": "session:state:{sessionId}", "ttl": "2h" },
        { "cache_name": "Agent状态", "key_pattern": "agent:state:{analysisId}", "ttl": "5min" },
        { "cache_name": "JWT黑名单", "key_pattern": "auth:blacklist:{tokenHash}", "ttl": "Token剩余有效期" }
      ]
    },
    "logging": {
      "java": "SLF4J + Logback",
      "prohibited": [
        "在循环中打印INFO及以上级别日志",
        "在日志中输出敏感信息（密码、Token、API Key）"
      ]
    },
    "security": {
      "password_storage": "BCrypt哈希，盐值随机，强度10",
      "auth_mechanism": "JWT Token (24h有效期) + Redis黑名单",
      "jwt_payload": ["sub(userId)", "username", "iat/exp", "jti(Token唯一ID)"],
      "sql_injection_prevention": "JPA参数化查询，禁止SQL拼接",
      "data_isolation": "WHERE user_id = currentUserId",
      "public_endpoints": ["/api/users/register", "/api/users/login"]
    }
  },
