# ============================================================
# XH-202630 科研文献智能助手 — AI服务环境变量配置
# 使用说明: 复制本文件为 .env 并填写实际值
# cp .env.example .env
# ============================================================

# --- 应用配置 ---
APP_NAME=Literature Assistant AI Service
DEBUG=False
HOST=0.0.0.0
PORT=8000

# --- ChromaDB配置 ---
CHROMA_PATH=./data/vector_db

# --- Embedding配置 ---
# 本地兜底模型(1024维, 与DashScope API对齐):
EMBEDDING_MODEL_PATH=BAAI/bge-m3
EMBEDDING_DEVICE=cpu
EMBEDDING_EXPECTED_DIMENSION=1024
# EMBEDDING_API_KEY=          # 外接Embedding API Key（备选方案，敏感值请勿提交）
# EMBEDDING_API_BASE=         # 外接Embedding API Base URL
# EMBEDDING_API_MODEL=        # 外接Embedding API 模型名

# --- 阿里云百炼/DashScope Embedding配置(优先) ---
# DASHSCOPE_API_KEY=          # 阿里云百炼API Key，用于text-embedding-v4，敏感值请勿提交
# DASHSCOPE_EMBEDDING_MODEL=  # 模型名，默认text-embedding-v4(1024维)
# DASHSCOPE_EMBEDDING_BASE_URL= # API端点，默认https://dashscope.aliyuncs.com/compatible-mode/v1

# --- LLM配置（三路并行，按优先级降级） ---
# 优先级：方案A(软件方模型) → 方案B(外接API) → 方案C(本地模型)
# 软件方URL未配置时自动跳过方案A，直接使用方案B
LLM_MODE=auto

# 方案A：软件方模型（最高优先级，需发榜单位提供URL后配置）
# LLM_BUILTIN_URL=              # 软件方模型API地址（待发榜单位提供）
# LLM_BUILTIN_API_KEY=          # 软件方内置API Key
# LLM_BUILTIN_MODEL=            # 软件方内置模型名

# 方案B：外接API（中等优先级，用户自配）
# 支持任何OpenAI兼容端点，以下为常见配置示例：
#
# DeepSeek:
# LLM_API_KEY=sk-xxx
# LLM_API_BASE=https://api.deepseek.com/v1
# LLM_MODEL_NAME=deepseek-chat
#
# 讯飞星火（OpenAI兼容模式）:
# LLM_API_KEY=xxx:xxx
# LLM_API_BASE=https://spark-api-open.xf-yun.com/v1
# LLM_MODEL_NAME=generalv3.5
#
# 通义千问:
# LLM_API_KEY=sk-xxx
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-plus
#
# 阿里云百炼:
# LLM_API_KEY=sk-xxx
# LLM_API_BASE=https://dashscope.aliyuncs.com/compatible-mode/v1
# LLM_MODEL_NAME=qwen-turbo
#
# LLM_API_KEY=               # 外接API Key（敏感值请勿提交）
# LLM_API_BASE=              # 外接API Base URL
# LLM_MODEL_NAME=            # 外接API 模型名

# 方案C：本地模型（最低优先级，兜底方案）
# 支持Transformers兼容模型，推荐配置：
#
# Qwen2-7B-Instruct（需GPU显存≥16GB）:
# LLM_LOCAL_MODEL_PATH=Qwen/Qwen2-7B-Instruct
#
# Qwen2-1.5B-Instruct（CPU可运行，约4GB内存）:
# LLM_LOCAL_MODEL_PATH=Qwen/Qwen2-1.5B-Instruct
#
# LLM_LOCAL_MODEL_PATH=      # 本地模型路径，如 Qwen/Qwen2-7B-Instruct

# LLM通用配置
LLM_TIMEOUT=30
LLM_RETRY_COUNT=1
LLM_RETRY_INTERVAL=3

# --- Agent配置 ---
AGENT_TIMEOUT=30
AGENT_FULL_TIMEOUT=120
AGENT_MAX_REGENERATE=1

# --- task47: RRF/Reranker 参数调优 ---
# RRF 融合 k 值（默认 60，ADR-005 决策依据）
RRF_K=60
# Reranker 复合评分主权重（和应≈1.0，允许±0.01误差，不一致时仅警告）
RERANKER_WEIGHT_RRF=0.5
RERANKER_WEIGHT_FIELD=0.3
RERANKER_WEIGHT_POPULARITY=0.2

# --- task51: LLM 流式优化 ---
LLM_STREAM_TIMEOUT=30

# --- task53: 外接 Embedding API 多 Provider 配置 ---
# 主 Provider 选择：dashscope / jina / openai
EMBEDDING_PROVIDER=dashscope
# 维度校验（所有 Provider 输出维度必须一致）
EMBEDDING_DIMENSION=1024
# Jina API Key（jina-embeddings-v3，1024维，敏感值请勿提交）
# JINA_API_KEY=
# OpenAI API Key（text-embedding-3-small，1536维截断前1024+L2归一化，敏感值请勿提交）
# OPENAI_API_KEY=

# --- task54: 检索参数优化 ---
# 混合检索返回结果数（范围 [5, 20]）
SEARCH_TOP_K=10
# 相似度阈值过滤（范围 [0.0, 0.9]，0.0 表示不过滤；ChromaDB distance < 1-threshold 保留）
SEARCH_SIMILARITY_THRESHOLD=0.0
# 论文分块大小（当前摘要+标题整体向量化，预留给未来长论文分块）
CHUNK_SIZE=512

# --- task55: 推荐策略权重 ---
# 最终分 = rerank_score × RERANK_WEIGHT + recommendation_score × RECOMMENDATION_WEIGHT
RERANK_WEIGHT=0.7
RECOMMENDATION_WEIGHT=0.3

# --- 日志配置 ---
LOG_LEVEL=INFO
