# ============================================================
# XH-202630 科研文献智能助手 — AI服务环境变量配置
# 使用说明: 复制本文件为 .env 并填写实际值
# cp .env.example .env
# ============================================================

# --- 应用配置 ---
APP_NAME=Literature Assistant AI Service
DEBUG=False
HOST=0.0.0.0
PORT=8000

# --- ChromaDB配置 ---
CHROMA_PATH=./data/vector_db

# --- Embedding配置 ---
EMBEDDING_MODEL_PATH=BAAI/bge-large-zh-v1.5
EMBEDDING_DEVICE=cpu
# EMBEDDING_API_KEY=          # 外接Embedding API Key（备选方案，敏感值请勿提交）
# EMBEDDING_API_BASE=         # 外接Embedding API Base URL
# EMBEDDING_API_MODEL=        # 外接Embedding API 模型名

# --- LLM配置（三路并行，auto模式按优先级降级） ---
# 优先级：方案A(软件方模型) → 方案B(外接API) → 方案C(本地模型)
LLM_MODE=auto

# 方案A：软件方模型（最高优先级，开箱即用）
LLM_BUILTIN_URL=https://llm.literature-assistant.com/v1
# LLM_BUILTIN_API_KEY=       # 软件方内置API Key（通常无需修改）
# LLM_BUILTIN_MODEL=         # 软件方内置模型名

# 方案B：外接API（中等优先级，用户自配）
# LLM_API_KEY=               # 外接API Key（敏感值请勿提交）
# LLM_API_BASE=              # 外接API Base URL，如 https://api.deepseek.com/v1
# LLM_MODEL_NAME=            # 外接API 模型名，如 deepseek-chat

# 方案C：本地模型（最低优先级，兜底方案）
# LLM_LOCAL_MODEL_PATH=      # 本地模型路径，如 Qwen/Qwen2-7B-Instruct

# LLM通用配置
LLM_TIMEOUT=30
LLM_RETRY_COUNT=1
LLM_RETRY_INTERVAL=3

# --- Agent配置 ---
AGENT_TIMEOUT=30
AGENT_FULL_TIMEOUT=120
AGENT_MAX_REGENERATE=1

# --- 日志配置 ---
LOG_LEVEL=INFO
